{
  "name": "sentinel-firewall",
  "version": "0.3.0",
  "description": "Open source signing firewall for AI agent wallets: policy engine + simulation + threat intel before anything gets signed.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sentinel-mcp": "dist/mcp/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "policies/example.policy.yaml"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/star7js/sentinel.git"
  },
  "homepage": "https://github.com/star7js/sentinel#readme",
  "bugs": {
    "url": "https://github.com/star7js/sentinel/issues"
  },
  "keywords": [
    "ai-agents",
    "wallet-security",
    "signing",
    "firewall",
    "transaction-simulation",
    "policy-engine",
    "ethereum",
    "eip-7702",
    "web3-security"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "npm run build && node demo/router-injection.mjs",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "viem": "^2.21.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  }
}
